{
  "name": "@marcelinodzn/ds-tokens",
  "version": "1.0.1",
  "description": "Design tokens and resolver for Jio Design System",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./variables": "./src/variables.json"
  },
  "files": [
    "dist",
    "src/variables.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/marcelinodzn/jio-design-system.git",
    "directory": "packages/ds-tokens"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "design-tokens",
    "figma",
    "tokens",
    "design-system"
  ],
  "author": "Jio Design Team",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
