 * @example
 * ```ts
 * const themes = getAvailableThemes();
 * // ['MyJio', 'JioHome', 'JioMart', 'JioFinance', 'JioGauSamridhhi', 'JioKrishi']
 * ```
 */
declare function getAvailableThemes(): string[];
/**
 * Get theme metadata
 *
 * @param themeName - Theme name (e.g., 'MyJio')
 * @returns Theme metadata or undefined if not found
 *
 * @example
