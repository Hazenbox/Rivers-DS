 * Available text/icon emphasis levels
 */
type TextEmphasis = 'High' | 'Medium' | 'Low';
/**
 * Available tinted emphasis levels (for icons/text on colored surfaces)
 */
type TintedEmphasis = 'High Tinted' | 'Medium Tinted' | 'Low Tinted';
/**
 * Color step numbers (100-2500 in increments of 100)
 */
type ColorStep = 100 | 200 | 300 | 400 | 500 | 600 | 700 | 800 | 900 | 1000 | 1100 | 1200 | 1300 | 1400 | 1500 | 1600 | 1700 | 1800 | 1900 | 2000 | 2100 | 2200 | 2300 | 2400 | 2500;
/**
 * Color utilities for type-safe token access
 */
declare const colors: {
    /**
     * Get a surface level color
     *
     * @param level - Surface level (1 or 2)
     * @param type - Surface type (Minimal, Subtle, Contrasting)
     * @param context - Token context
     * @returns Color value (string) or null if not resolved
     *
     * @example
     * const surface1 = colors.surfaceLevel(1, 'Minimal', tokenContext);
     * const surface2 = colors.surfaceLevel(2, 'Subtle', tokenContext);
