/**
 * Figma Variables JSON Schema Types
 * Based on OneUI Design Kit [BETA]-variables-full.json
 */
interface FigmaVariablesJSON {
    schemaVersion: number;
    lastModified: string;
    collections: VariableCollection[];
}
interface VariableCollection {
    id: string;
    name: string;
    key: string;
    hiddenFromPublishing: boolean;
    defaultModeId: string;
    modes: Mode[];
    remote: boolean;
    variableIds: string[];
    variables?: Variable[];
}
interface Mode {
    name: string;
    modeId: string;
}
interface Variable {
    id: string;
    name: string;
    description?: string;
    key: string;
    resolvedType: ResolvedType;
    valuesByMode: Record<string, VariableValue>;
    scopes: string[];
    hiddenFromPublishing: boolean;
    codeSyntax: Record<string, unknown>;
    variableCollectionId: string;
}
type ResolvedType = 'COLOR' | 'FLOAT' | 'STRING' | 'BOOLEAN';
type VariableValue = ColorValue | NumberValue | StringValue | BooleanValue | VariableAlias;
interface ColorValue {
    r: number;
    g: number;
    b: number;
    a?: number;
}
type NumberValue = number;
type StringValue = string;
type BooleanValue = boolean;
interface VariableAlias {
    type: 'VARIABLE_ALIAS';
    id: string;
}
/**
 * Collection and Mode Resolution Types
 */
interface CollectionInfo {
    modes: string[];
    defaultMode: string;
    id: string;
}
type CollectionMap = Record<string, CollectionInfo>;
interface ModesByCollectionName {
    [collectionName: string]: string;
}
/**
 * Token Resolution Context
 * Used to resolve tokens for specific component states
 */
interface TokenContext {
    /** Platform: "Mobile (360)", "Tablet (768)", "Desktop (1440)", etc. */
    platform?: string;
    /** Density: "Default", "Compact", "Open" */
    density?: string;
    /** Color Mode: "Light", "Dark" */
    colorMode?: string;
    /** Surface level: 0, 1, 2 */
    surface?: string;
    /** Appearance: "↓Brand Appearance", "↓Semantic" */
    appearance?: string;
    /** Theme variant */
    theme?: string;
    /** Transparency level */
    transparency?: string;
    /** Any additional collection modes */
    [collectionName: string]: string | undefined;
}
/**
 * Resolved CSS value types
 */
type CSSValue = string | number;
interface ResolvedTokenValue {
    /** The raw resolved value from Figma */
    raw: VariableValue;
    /** The CSS-compatible value */
    css: CSSValue;
    /** The original variable that was resolved */
    variable: Variable;
}
/**
 * Design System Token Categories
 * Based on button.md specifications
 */
interface DesignTokens {
    shape: {
        Pill: CSSValue;
    };
    dimension: {
        XS: CSSValue;
        '2XS': CSSValue;
        S: CSSValue;
        M: CSSValue;
        L: CSSValue;
        XL: CSSValue;
        '2XL': CSSValue;
    };
    surface: {
        emphasis: {
            Bold: Record<string, CSSValue>;
            Subtle: Record<string, CSSValue>;
            Ghost: Record<string, CSSValue>;
        };
    };
    text: {
        attention: {
            high: CSSValue;
            medium: CSSValue;
            low: CSSValue;
        };
    };
    motion: {
        duration: {
            instant: CSSValue;
            quick: CSSValue;
            moderate: CSSValue;
        };
        easing: {
            standard: string;
            emphasized: string;
        };
    };
}
/**
 * Variable Resolution Options
 */
interface ResolveOptions {
    /** The mode context for resolution */
    context?: TokenContext;
    /** Whether to return CSS-compatible values */
    asCSSValue?: boolean;
    /** Maximum depth for alias resolution (prevent infinite loops) */
    maxDepth?: number;
}
/**
 * Error types for token resolution
 */
declare class TokenResolutionError extends Error {
    variableId?: string | undefined;
    variableName?: string | undefined;
    context?: TokenContext | undefined;
    constructor(message: string, variableId?: string | undefined, variableName?: string | undefined, context?: TokenContext | undefined);
}
declare class CircularReferenceError extends TokenResolutionError {
    constructor(variableId: string, chain: string[]);
}
declare class UnresolvedTokenError extends TokenResolutionError {
    constructor(variableId: string, variableName?: string, context?: TokenContext);
}

