    primitive(colorName: string, step: ColorStep, context: TokenContext): CSSValue | null;
    /**
     * Available surface levels
     */
    surfaceLevels: SurfaceLevel[];
    /**
     * Available surface types
     */
    surfaceTypes: SurfaceType[];
    /**
     * Available background variants
     */
    backgroundVariants: BackgroundVariant[];
    /**
     * Available text/icon emphasis levels
     */
    emphases: TextEmphasis[];
    /**
     * Available tinted emphasis levels
     */
    tintedEmphases: TintedEmphasis[];
    /**
     * Available color steps
     */
    steps: ColorStep[];
};

/**
 * Theme Registry
 *
 * Token-driven theme/brand discovery system.
 * Discovers available themes from Figma Variables JSON (no hardcoded lists).
 *
 * CRITICAL: Themes are derived from Theme Pack1 and Pack2 collections.
 * Adding a new theme in Figma automatically makes it available here.
 */
/**
 * Theme metadata
 */
interface ThemeMetadata {
    /**
     * Theme name (e.g., 'MyJio', 'JioHome')
     */
    name: string;
    /**
     * Theme pack (1 or 2)
     */
    pack: 1 | 2;
    /**
     * Collection name in Figma
     */
    collectionName: string;
    /**
     * Display name (formatted for UI)
     */
    displayName: string;
    /**
     * Theme category (derived from pack)
     */
    category: 'primary' | 'secondary';
}
/**
 * Get all available themes
