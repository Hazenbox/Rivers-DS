/**
 * Chart Utilities for Token Resolution
 *
 * Provides mode mapping and context adaptation for chart components,
 * bridging between dataviz naming conventions and ds-react token system.
 */

/**
 * Dataviz to ds-react Platform mode mapping
 * Handles naming differences between dataviz and ds-react
 *
 * Dataviz uses: Mobile360, Tablet768, Desktop1440, etc.
 * DS-React uses: Mobile (360), Tablet (768), Desktop (1440), etc.
 */
declare const DATAVIZ_PLATFORM_MAP: Record<string, string>;
/**
 * Dataviz theme mapping to ds-react Theme Pack system
 * Maps old colourTheme to new Theme Pack structure
 */
declare const DATAVIZ_THEME_MAP: Record<string, {
    pack: string;
    theme: string;
}>;
/**
 * Dataviz-style context format for chart components
 * This is the legacy format from the original dataviz implementation
 */
interface DatavizContext {
    Platform?: string;
    Density?: string;
    colourTheme?: string;
    colourMode?: string;
    barWidth?: string;
    interactiveState?: 'idle' | 'hover' | 'pressed';
}
/**
 * Normalize dataviz platform name to ds-react format
 *
 * @param platform - Platform name in dataviz format (e.g., 'Mobile360')
 * @returns Platform name in ds-react format (e.g., 'Mobile (360)')
 *
 * @example
 * normalizeDatavizPlatform('Mobile360') // => 'Mobile (360)'
 * normalizeDatavizPlatform('Desktop1440') // => 'Desktop (1440)'
 */
declare function normalizeDatavizPlatform(platform: string): string;
/**
 * Convert ds-react platform name to dataviz format
 * Inverse of normalizeDatavizPlatform
 *
 * @param platform - Platform name in ds-react format
 * @returns Platform name in dataviz format
 *
 * @example
 * toDatavizPlatform('Mobile (360)') // => 'Mobile360'
 */
declare function toDatavizPlatform(platform: string): string;
/**
 * Convert dataviz context to ds-react TokenContext
 *
 * Handles all the naming and structural differences:
 * - Platform name normalization (Mobile360 → Mobile (360))
 * - Collection name mapping (colourTheme → Theme, colourMode → Color Mode)
 * - Theme Pack resolution (colourTheme → Theme Pack + Theme Pack1/2)
 * - Bar width integration
 *
 * @param datavizContext - Context in dataviz format
 * @returns TokenContext in ds-react format for use with getVariableByName
 *
 * @example
 * const context = adaptDatavizContext({
 *   Platform: 'Mobile360',
 *   Density: 'Default',
 *   colourTheme: 'JioFinance',
 *   colourMode: 'Light',
 *   barWidth: 'M',
 * });
 * // Returns:
 * // {
 * //   '1. Platform': 'Mobile (360)',
 * //   '2. Density': 'Default',
 * //   '3. Color Mode': 'Light',
 * //   '6. 󠀅Theme': '↓Pack1',
 * //   '󠀆├ Theme Pack1': 'JioFinance',
 * //   'Chart/Bar Width': 'M'
 * // }
 */
declare function adaptDatavizContext(datavizContext: DatavizContext): TokenContext;
/**
 * Create a chart context with dataviz defaults
 *
 * Convenience function for creating a full chart context
 * with all required collections for chart rendering
 *
 * @param overrides - Override individual values
 * @returns TokenContext with chart defaults
 *
 * @example
 * const context = createChartContext({
 *   Platform: 'Mobile360',
 *   colourTheme: 'JioFinance',
 *   barWidth: 'L'
 * });
 */
declare function createChartContext(overrides?: Partial<DatavizContext>): TokenContext;
/**
 * Validate that a dataviz context is valid
 *
 * @param context - Context to validate
 * @returns true if context is valid, false otherwise
 */
declare function isValidDatavizContext(context: any): context is DatavizContext;

/**
 * Spacing Foundation Utilities
 *
 * Type-safe helpers for accessing spacing tokens.
 * All spacing values are resolved from Figma variables.
 *
 * @example
 * import { spacing } from '@jio/ds-tokens/foundations';
 *
 * const padding = spacing.get('M', tokenContext); // Returns number (e.g., 16)
 */

/**
 * Available spacing sizes in the design system
 */
type SpacingSize = '3XS' | '2XS' | 'XS' | 'S' | 'M' | 'L' | 'XL' | '2XL' | '3XL' | '4XL';
/**
 * Spacing utilities for type-safe token access
 */
declare const spacing: {
    /**
     * Get a spacing value by size
     *
     * @param size - The spacing size (3XS through 4XL)
     * @param context - Token context with platform, density, colorMode, etc.
     * @returns Spacing value (typically number in pixels) or null if not resolved
     *
     * @example
     * const padding = spacing.get('M', tokenContext); // 16
     * const margin = spacing.get('L', tokenContext);  // 24
     */
    get(size: SpacingSize, context: TokenContext): CSSValue | null;
    /**
     * Get multiple spacing values at once
     *
     * @param sizes - Array of spacing sizes
     * @param context - Token context
     * @returns Object with size keys and values
     *
     * @example
     * const spaces = spacing.getMultiple(['XS', 'S', 'M'], tokenContext);
     * // { XS: 4, S: 8, M: 16 }
     */
    getMultiple(sizes: SpacingSize[], context: TokenContext): Record<SpacingSize, CSSValue | null>;
    /**
     * All available spacing sizes
     */
    sizes: SpacingSize[];
};

/**
 * Typography Foundation Utilities
 *
 * Type-safe helpers for accessing typography tokens.
 * All typography values are resolved from Figma variables.
 *
 * @example
 * import { typography } from '@jio/ds-tokens/foundations';
 *
 * const size = typography.fontSize('Label', 'M', tokenContext); // Returns number (e.g., 14)
 * const weight = typography.fontWeight('Label', 'High', tokenContext); // Returns number (e.g., 600)
 */

/**
 * Available typography scale types
 */
type TypographyType = 'Display' | 'Title' | 'Headline' | 'Body' | 'Label';
/**
 * Available typography sizes
 */
type TypographySize = '3XS' | '2XS' | 'XS' | 'S' | 'M' | 'L' | 'XL' | '2XL';
/**
 * Available font weight emphasis levels
 */
type FontWeightEmphasis = 'Low' | 'Medium' | 'High';
/**
 * Typography utilities for type-safe token access
 */
declare const typography: {
    /**
     * Get a font size value
     *
     * @param type - The typography type (Display, Title, Headline, Body, Label)
     * @param size - The size variant (3XS through 2XL)
     * @param context - Token context
     * @returns Font size in pixels (number) or null if not resolved
     *
     * @example
     * const labelSize = typography.fontSize('Label', 'M', tokenContext); // 14
     * const titleSize = typography.fontSize('Title', 'L', tokenContext); // 24
     */
    fontSize(type: TypographyType, size: TypographySize, context: TokenContext): CSSValue | null;
    /**
     * Get a font weight value
     *
     * @param type - The typography type (Display, Title, Headline, Body, Label)
     * @param emphasis - Weight emphasis (Low, Medium, High)
     * @param context - Token context
     * @returns Font weight (number, e.g., 400, 600) or null if not resolved
     *
     * @example
     * const labelWeight = typography.fontWeight('Label', 'High', tokenContext); // 600
     * const bodyWeight = typography.fontWeight('Body', 'Low', tokenContext); // 400
     */
    fontWeight(type: TypographyType, emphasis: FontWeightEmphasis, context: TokenContext): CSSValue | null;
    /**
     * Get the primary font family
     *
     * @param context - Token context
     * @returns Font family name (string) or null if not resolved
     *
     * @example
     * const fontFamily = typography.fontFamily(tokenContext); // "JioType Var"
     */
    fontFamily(context: TokenContext): CSSValue | null;
    /**
     * Get the code font family
     *
     * @param context - Token context
     * @returns Font family name for code (string) or null if not resolved
     *
     * @example
     * const codeFontFamily = typography.codeFontFamily(tokenContext); // "monospace"
     */
    codeFontFamily(context: TokenContext): CSSValue | null;
    /**
     * Get complete typography styles for a type and size
     *
     * @param type - The typography type
     * @param size - The size variant
     * @param emphasis - Weight emphasis (defaults to 'Medium')
     * @param context - Token context
     * @returns Object with fontSize, fontWeight, and fontFamily
     *
     * @example
     * const labelStyles = typography.getStyles('Label', 'M', 'High', tokenContext);
     * // { fontSize: 14, fontWeight: 600, fontFamily: "JioType Var" }
     */
    getStyles(type: TypographyType, size: TypographySize, emphasis: FontWeightEmphasis, context: TokenContext): {
        fontSize: CSSValue | null;
        fontWeight: CSSValue | null;
        fontFamily: CSSValue | null;
    };
    /**
     * Available typography types
     */
    types: TypographyType[];
    /**
     * Available sizes
     */
    sizes: TypographySize[];
    /**
     * Available weight emphasis levels
     */
    emphases: FontWeightEmphasis[];
};

/**
 * Color Foundation Utilities
 *
 * Type-safe helpers for accessing color tokens.
 * All color values are resolved from Figma variables.
 *
 * @example
 * import { colors } from '@jio/ds-tokens/foundations';
 *
 * const bgColor = colors.background('Bold', tokenContext); // Returns color value
 * const textColor = colors.text('High', tokenContext); // Returns color value
 * const surfaceColor = colors.surfaceLevel(1, 'Minimal', tokenContext); // Returns color value
 */

/**
 * Surface level (1 or 2)
 */
type SurfaceLevel = 1 | 2;
/**
 * Available surface types for surface levels
 */
type SurfaceType = 'Minimal' | 'Subtle' | 'Contrasting';
/**
 * Available background variants (Neutral appearance)
 */
type BackgroundVariant = 'Blend' | 'Bold' | 'Contrasting' | 'Elevated High' | 'Elevated Low' | 'Ghost' | 'Subtle';
