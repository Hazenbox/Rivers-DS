     * Get icon color with tinted emphasis (for use on colored surfaces)
     *
     * @param emphasis - Tinted emphasis level
     * @param context - Token context
     * @returns Color value (string) or null if not resolved
     *
     * @example
     * const tintedIcon = colors.iconTinted('High Tinted', tokenContext);
     */
    iconTinted(emphasis: TintedEmphasis, context: TokenContext): CSSValue | null;
    /**
     * Get a semantic color (Positive, Warning, Negative)
     *
     * @param semantic - Semantic color name
     * @param variant - Color variant (e.g., 'Background/Bold', 'Text/High')
     * @param context - Token context
     * @returns Color value (string) or null if not resolved
     *
     * @example
     * const successBg = colors.semantic('Positive', 'Background/Bold', tokenContext);
     * const errorText = colors.semantic('Negative', 'Text/High', tokenContext);
     * const warningIcon = colors.semantic('Warning', 'Icon/High', tokenContext);
     */
    semantic(semantic: "Positive" | "Warning" | "Negative", variant: string, context: TokenContext): CSSValue | null;
    /**
     * Get an appearance-based color (Primary, Secondary, etc.)
     *
     * @param appearance - Appearance name (Primary, Secondary, Sparkle, etc.)
     * @param variant - Color variant (e.g., 'Background/Bold', 'Text/High')
     * @param context - Token context
     * @returns Color value (string) or null if not resolved
     *
     * @example
     * const primaryBg = colors.appearance('Primary', 'Background/Bold', tokenContext);
     * const secondaryText = colors.appearance('Secondary', 'Text/High', tokenContext);
     */
    appearance(appearance: "Primary" | "Secondary" | "Sparkle" | "Neutral", variant: string, context: TokenContext): CSSValue | null;
