    surfaceLevel(level: SurfaceLevel, type: SurfaceType, context: TokenContext): CSSValue | null;
    /**
     * Get a background color (Neutral appearance)
     *
     * @param variant - Background variant
     * @param context - Token context
     * @returns Color value (string) or null if not resolved
     *
     * @example
     * const bgBold = colors.background('Bold', tokenContext);
     * const bgSubtle = colors.background('Subtle', tokenContext);
     * const bgGhost = colors.background('Ghost', tokenContext);
     */
    background(variant: BackgroundVariant, context: TokenContext): CSSValue | null;
    /**
     * Get a text color by emphasis (Neutral appearance)
     *
     * @param emphasis - Text emphasis level (High, Medium, Low)
     * @param context - Token context
     * @returns Color value (string) or null if not resolved
     *
     * @example
     * const primaryText = colors.text('High', tokenContext);
     * const secondaryText = colors.text('Medium', tokenContext);
     */
    text(emphasis: TextEmphasis, context: TokenContext): CSSValue | null;
    /**
     * Get an icon color by emphasis (Neutral appearance)
     *
     * @param emphasis - Icon emphasis level (High, Medium, Low)
     * @param context - Token context
     * @returns Color value (string) or null if not resolved
     *
     * @example
     * const iconPrimary = colors.icon('High', tokenContext);
     * const iconSecondary = colors.icon('Medium', tokenContext);
     */
    icon(emphasis: TextEmphasis, context: TokenContext): CSSValue | null;
    /**
     * Get text color with tinted emphasis (for use on colored surfaces)
     *
     * @param emphasis - Tinted emphasis level
     * @param context - Token context
     * @returns Color value (string) or null if not resolved
     *
     * @example
     * const tintedText = colors.textTinted('High Tinted', tokenContext);
     */
    textTinted(emphasis: TintedEmphasis, context: TokenContext): CSSValue | null;
